{
  "name": "sho-hatha",
  "private": true,
  "workspaces": [
    "apps/client",
    "apps/server"
  ],
  "scripts": {
    "dev": "concurrently -n client,server -c cyan,green \"npm run dev -w @sho-hatha/client\" \"npm run dev -w @sho-hatha/server\"",
    "dev:client": "npm run dev -w @sho-hatha/client",
    "dev:server": "npm run dev -w @sho-hatha/server",
    "build": "npm run build --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "test:coverage": "npm run test:coverage --workspaces --if-present",
    "db:generate": "npm run db:generate -w @sho-hatha/server",
    "db:migrate": "npm run db:migrate -w @sho-hatha/server",
    "db:migrate:deploy": "npm run db:migrate:deploy -w @sho-hatha/server",
    "db:seed": "npm run db:seed -w @sho-hatha/server",
    "db:studio": "npm run db:studio -w @sho-hatha/server"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
