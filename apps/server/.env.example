NODE_ENV=development
PORT=3001
# For local IPv4-only environments (for example WSL without IPv6), use the
# Supabase Session pooler connection string from Connect -> ORMs -> Prisma.
DATABASE_URL=postgresql://postgres.project-ref:password@aws-0-region.pooler.supabase.com:5432/postgres
CORS_ORIGIN=http://localhost:5173
ADMIN_API_TOKEN=change-me-use-openssl-rand-base64-32
QUESTIONS_PER_GAME=18
CATEGORIES_TO_DISPLAY=6
CATEGORIES_PER_TEAM=3
LOG_LEVEL=info
